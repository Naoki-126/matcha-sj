{%- if section.settings.enable -%}
  <div
    id="jm-popup"
    class="jm-popup"
    aria-hidden="true"
    data-delay="{{ section.settings.delay | default: 2 }}"
    data-home-only="{{ section.settings.home_only }}"
    data-is-home="{% if request.page_type == 'index' %}true{% else %}false{% endif %}"
  >
    <div class="jm-popup__overlay"></div>

    <div class="jm-popup__content">
      <button type="button" class="jm-popup__close" aria-label="Close">×</button>

      <div id="jm-popupStep1" class="jm-popup__step is-active">
        <h2 class="jm-popup__title">Want 15% Off Your First Order?</h2>

        <div class="jm-popup__actions">
          <button type="button" id="jm-popupYes" class="jm-btn">Yes</button>
          <button type="button" id="jm-popupNo" class="jm-popup__text-btn">No, thank you</button>
        </div>
      </div>

      <div id="jm-popupStep2" class="jm-popup__step" style="display:none;">
        <div class="jm-popup__step2Layout">
          <div class="jm-popup__step2Text">
            <h2 class="jm-popup__title">Want 15% Off Your First Order?</h2>

            <div class="jm-popup__text">
              <p>Enjoy 15% off the best matcha on this earth.</p>
              <p>Join our list for exclusive releases, rare harvests, and special offers.</p>
            </div>

            {% assign popup_success = false %}

            {% form 'customer', id: 'jm-popupForm', class: 'jm-popup__btnArea' %}
              <input type="hidden" name="contact[tags]" value="newsletter">

              <input
                type="email"
                name="contact[email]"
                placeholder="Enter your email"
                class="jm-popup__form"
                required
                oninvalid="this.setCustomValidity(this.validity.valueMissing ? 'Please enter your email address.' : 'Please enter a valid email address.')"
                oninput="this.setCustomValidity('')"
              >

              <button type="submit" class="jm-popup__submit">
                Get 15% Off
              </button>

              {% if form.posted_successfully? %}
                {% assign popup_success = true %}
              {% endif %}
            {% endform %}

            <div
              id="jm-popupFormSuccessFlag"
              data-success="{% if popup_success %}true{% else %}false{% endif %}"
              hidden
            ></div>

            <div id="jm-popupSuccess" class="jm-popup__success" style="display:none;">
              <p class="jm-popup__successTitle">🎉 Thank you for signing up!</p>
              <p class="jm-popup__successLead">Your 15% discount code:</p>

              <button
                id="jm-discountCode"
                class="jm-popup__coupon"
                type="button"
                data-code="DISCOUNT15"
              >
                DISCOUNT15
              </button>

              <p class="jm-popup__successGuide">Copy this code and paste it at checkout to enjoy your 15% discount.</p>
              <p id="jm-popupCopyMessage" class="jm-popup__copyMessage" style="display:none;">
                Copied!
              </p>

              <p class="jm-popup__successText">
                Use this code at checkout and enjoy your first order.
              </p>

              <div class="jm-popup__successActions">
                <a href="/collections/all" class="jm-popup__shopBtn">Shop Now</a>
                <button id="jm-popupAfterSuccess" class="jm-popup__closeBtn" type="button">
                  Close
                </button>
              </div>
            </div>
          </div>

          <div class="jm-popup__step2Image">
            {% if section.settings.step2_image != blank %}
              {{ section.settings.step2_image | image_url: width: 900 | image_tag:
                class: 'jm-popup__image',
                alt: section.settings.step2_image_alt | escape
              }}
            {% else %}
              <div class="jm-popup__imagePlaceholder"></div>
            {% endif %}
          </div>
        </div>
      </div>

    </div>
  </div>

    <div
    id="jm-popup-teaser"
    class="jm-popup-teaser"
    data-default-label="Get 15% OFF"
    data-registered-label="Your code: DISCOUNT15"
    data-discount-code="DISCOUNT15"
  >
    <button
      type="button"
      class="jm-popup-teaser__btn"
      aria-label="Open popup"
    >
      <span id="jm-popupTeaserLabel">Get 15% OFF</span>
    </button>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Mail Popup",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable",
      "label": "Enable popup",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "home_only",
      "label": "Show only on homepage",
      "default": true
    },
    {
      "type": "range",
      "id": "delay",
      "label": "Delay (seconds)",
      "min": 0,
      "max": 10,
      "step": 1,
      "default": 2
    },
    {
      "type": "image_picker",
      "id": "step2_image",
      "label": "STEP2 image"
    },
    {
      "type": "text",
      "id": "step2_image_alt",
      "label": "STEP2 image alt text",
      "default": "Matcha image"
    }
  ],
  "presets": [
    {
      "name": "Mail Popup"
    }
  ]
}
{% endschema %}
