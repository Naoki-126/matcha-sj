{%- if section.settings.enable -%}
<div
  id="jm-popup"
  class="jm-popup"
  aria-hidden="true"
  data-delay="{{ section.settings.delay | default: 2 }}"
  data-home-only="{{ section.settings.home_only }}"
  data-is-home="{% if request.page_type == 'index' %}true{% else %}false{% endif %}"
>
  <div class="jm-popup__overlay"></div>

  <div class="jm-popup__content">
    <button type="button" class="jm-popup__close" aria-label="Close">×</button>

    <!-- STEP 1 -->
    <div id="jm-popupStep1" class="jm-popup__step is-active">
      <h2 class="jm-popup__title">Want 15% Off Your First Order?</h2>

      <div class="jm-popup__actions">
        <button type="button" id="jm-popupYes" class="jm-btn">
          Yes
        </button>
        <button type="button" id="jm-popupNo" class="jm-popup__text-btn">
          No, thank you
        </button>
      </div>
    </div>

    <!-- STEP 2 -->
    <div id="jm-popupStep2" class="jm-popup__step" style="display:none;">
      <div class="jm-popup__step2Layout">
        <div class="jm-popup__step2Text">
          <h2 class="jm-popup__title">Want 15% Off Your First Order?</h2>

          <div class="jm-popup__text">
            <p>Enjoy 15% off the best matcha on this earth.</p>
            <p>Join our list for exclusive releases, rare harvests, and special offers.</p>
          </div>

          {% form 'customer', id: 'jm-popupForm', class: 'jm-popup__btnArea' %}
            <input type="hidden" name="contact[tags]" value="newsletter">

            <input
              type="email"
              name="contact[email]"
              placeholder="Enter your email"
              class="jm-popup__form"
              required
              oninvalid="this.setCustomValidity('Please enter your email address.')"
              oninput="this.setCustomValidity('')"
            >

            <button type="submit" class="jm-btn">
              Unlock offer
            </button>

            {% if form.errors %}
              <div class="jm-popup__error">
                {{ form.errors | default_errors }}
              </div>
            {% endif %}

            {% if form.posted_successfully? %}
              <div id="jm-popupFormSuccessFlag" data-success="true" hidden></div>
            {% endif %}
          {% endform %}

          <div id="jm-popupSuccess" class="jm-popup__success" style="display:none;">
            <p>Thank you for signing up!</p>
            <p>Your 15% discount code:</p>
            <p><strong id="jm-discountCode">DISCOUNT15</strong></p>
            <p>Enjoy your first order.</p>
            <button id="jm-popupAfterSuccess" type="button">Close</button>
          </div>
        </div>

        <div class="jm-popup__step2Image">
          {% if section.settings.step2_image != blank %}
            {{ section.settings.step2_image | image_url: width: 900 | image_tag:
              class: 'jm-popup__image',
              alt: section.settings.step2_image_alt | escape
            }}
          {% else %}
            <div class="jm-popup__imagePlaceholder"></div>
          {% endif %}
        </div>
      </div>
    </div>

  </div>
</div>

<!-- teaser -->
<div id="jm-popup-teaser" class="jm-popup-teaser">
  <button type="button" class="jm-popup-teaser__btn" aria-label="Open email signup popup">
    <span>Get 15% OFF</span>
  </button>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Mail Popup",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable",
      "label": "Enable popup",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "home_only",
      "label": "Show only on homepage",
      "default": true
    },
    {
      "type": "range",
      "id": "delay",
      "label": "Delay (seconds)",
      "min": 0,
      "max": 10,
      "step": 1,
      "default": 2
    },
    {
      "type": "image_picker",
      "id": "step2_image",
      "label": "STEP2 image"
    },
    {
      "type": "text",
      "id": "step2_image_alt",
      "label": "STEP2 image alt text",
      "default": "Matcha image"
    }
  ],
  "presets": [
    {
      "name": "Mail Popup"
    }
  ]
}
{% endschema %}
